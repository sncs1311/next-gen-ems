// ============================================================
// EMS — ERD DOMAIN GROUP 3: OPERATIONS DOMAIN
// Entities: Project, WarehouseYardLocation,
//           ProjectSiteEngineerAssignment,
//           AssetSiteAssignment, AssetOperatorAssignment,
//           FuelLog, FuelAnomaly,
//           SiteFuelTank, SiteFuelDelivery,
//           UtilizationLog, SparePart
// ============================================================

Table Project {
  id                      uuid        [pk]
  project_code            varchar(30) [unique, not null, note: "Format: PRJ-QAT-2024-001"]
  project_name            varchar(300)[not null]
  client_name             varchar(200)[not null]
  sector                  varchar(50) [not null, note: "Oil-Gas / Refinery / Infrastructure / Marine / Power"]
  city                    varchar(100)[not null]
  country                 varchar(10) [not null, note: "QAT / UAE / SAU / OMN / KWT / BHR"]
  site_gps_lat            decimal(10,7)
  site_gps_lng            decimal(10,7)
  start_date              date        [not null]
  planned_completion_date date        [not null]
  actual_completion_date  date
  project_manager_id      uuid        [not null, note: "FK to Employee"]
  project_status          varchar(30) [not null, default: "Mobilization", note: "Mobilization / Active / On-Hold / Demobilization / Completed"]
  is_archived             boolean     [not null, default: false]
  created_at              timestamptz [not null, default: `now()`]
  updated_at              timestamptz [not null, default: `now()`]
}

Table WarehouseYardLocation {
  id              uuid        [pk]
  location_code   varchar(20) [unique, not null, note: "e.g. YARD-HQ-01, WKSHP-MAIN"]
  location_name   varchar(200)[not null, note: "e.g. Main Equipment Yard, Central Workshop"]
  location_type   varchar(30) [not null, note: "Yard / Workshop / Staging-Area"]
  city            varchar(100)
  country         varchar(10)
  gps_lat         decimal(10,7)
  gps_lng         decimal(10,7)
  is_active       boolean     [not null, default: true]
  created_at      timestamptz [not null, default: `now()`]
  updated_at      timestamptz [not null, default: `now()`]
}

Table ProjectSiteEngineerAssignment {
  id              uuid        [pk]
  project_id      uuid        [not null, ref: > Project.id]
  employee_id     uuid        [not null, note: "FK to Employee — must have Site Engineer role"]
  assigned_from   date        [not null]
  assigned_to     date        [note: "Null if currently active"]
  created_at      timestamptz [not null, default: `now()`]

  indexes {
    (project_id, employee_id, assigned_from) [unique]
    (project_id, assigned_to)
  }
}

Table AssetSiteAssignment {
  id                      uuid        [pk]
  asset_id                uuid        [not null, note: "FK to Asset"]
  project_id              uuid        [ref: > Project.id, note: "Populated if assigned to a project. Null if in yard."]
  yard_location_id        uuid        [ref: > WarehouseYardLocation.id, note: "Populated if in yard. Null if on project."]
  assigned_from           timestamptz [not null]
  assigned_to             timestamptz [note: "Null if current assignment"]
  assigned_by             uuid        [not null, note: "FK to Employee — Fleet Manager who approved"]
  transfer_request_id     uuid        [note: "FK to TransferRequest that triggered this assignment"]
  notes                   text

  indexes {
    (asset_id, assigned_to)
    (project_id, assigned_to)
  }

  note: "CHECK: project_id IS NOT NULL XOR yard_location_id IS NOT NULL — exactly one must be populated"
}

Table AssetOperatorAssignment {
  id              uuid        [pk]
  asset_id        uuid        [not null, note: "FK to Asset"]
  driver_id       uuid        [not null, note: "FK to Driver"]
  project_id      uuid        [ref: > Project.id]
  shift           varchar(10) [not null, note: "AM / PM / Night / Full-Day"]
  assignment_date date        [not null]
  start_time      time
  end_time        time
  assigned_by     uuid        [not null, note: "FK to Employee"]
  notes           text
  created_at      timestamptz [not null, default: `now()`]

  indexes {
    (asset_id, assignment_date, shift) [unique]
    (driver_id, assignment_date)
  }
}

Table SiteFuelTank {
  id              uuid        [pk]
  project_id      uuid        [not null, ref: > Project.id]
  tank_code       varchar(30) [unique, not null, note: "e.g. TANK-PRJ001-D1"]
  fuel_type       varchar(20) [not null, note: "Diesel / Petrol"]
  capacity_liters decimal(10,2)[not null]
  current_balance_liters decimal(10,2)[not null, default: 0, note: "Recomputed on each delivery or dispensing"]
  location_description text
  is_active       boolean     [not null, default: true]
  created_at      timestamptz [not null, default: `now()`]
  updated_at      timestamptz [not null, default: `now()`]
}

Table SiteFuelDelivery {
  id                  uuid        [pk]
  tank_id             uuid        [not null, ref: > SiteFuelTank.id]
  vendor_id           uuid        [not null, note: "FK to Vendor — fuel supplier"]
  delivery_date       date        [not null]
  quantity_liters     decimal(10,2)[not null]
  unit_price          decimal(8,4)[not null]
  total_cost          decimal(12,2)[not null]
  currency            varchar(5)  [not null]
  delivery_note_number varchar(100)
  po_reference        varchar(100)
  received_by         uuid        [not null, note: "FK to Employee — Site Engineer who received"]
  notes               text
  created_at          timestamptz [not null, default: `now()`]

  indexes {
    (tank_id, delivery_date desc)
  }
}

Table FuelLog {
  id                      uuid        [pk]
  asset_id                uuid        [not null, note: "FK to Asset"]
  driver_id               uuid        [not null, note: "FK to Driver — operator on duty"]
  project_id              uuid        [not null, ref: > Project.id]
  tank_id                 uuid        [ref: > SiteFuelTank.id, note: "Null if fueled at external station"]
  logged_at               timestamptz [not null, note: "Date and time of fueling"]
  fuel_type               varchar(20) [not null]
  quantity_liters         decimal(8,2)[not null]
  meter_reading_km        decimal(10,2)[note: "Odometer — for vehicles only"]
  meter_reading_hours     decimal(10,2)[note: "Hour meter — for equipment only"]
  fuel_source             varchar(30) [not null, note: "Company-Tank / External-Station / Bowser"]
  voucher_reference       varchar(100)
  unit_price              decimal(8,4)
  total_cost              decimal(12,2)
  currency                varchar(5)
  calculated_efficiency   decimal(8,4)[note: "km/L for vehicles, L/hr for equipment. Auto-calculated."]
  rolling_avg_efficiency  decimal(8,4)[note: "30-day rolling average at time of entry"]
  is_correction           boolean     [not null, default: false, note: "True if this entry corrects a previous entry"]
  corrects_log_id         uuid        [ref: > FuelLog.id, note: "Self-ref: points to the original entry being corrected"]
  entered_by              uuid        [not null, note: "FK to Employee"]
  created_at              timestamptz [not null, default: `now()`]

  indexes {
    (asset_id, logged_at desc)
    (project_id, logged_at desc)
    (driver_id, logged_at desc)
  }
}

Table FuelAnomaly {
  id                      uuid        [pk]
  fuel_log_id             uuid        [unique, not null, ref: - FuelLog.id]
  asset_id                uuid        [not null, note: "FK to Asset — denormalized for query performance"]
  anomaly_type            varchar(50) [not null, note: "Overconsumption / Underconsumption / Tank-Exceeded"]
  expected_min            decimal(8,4)[not null]
  expected_max            decimal(8,4)[not null]
  actual_value            decimal(8,4)[not null]
  deviation_percent       decimal(6,2)[not null]
  alert_generated         boolean     [not null, default: false]
  reviewed_by             uuid        [note: "FK to Employee — Fleet Manager who reviewed"]
  reviewed_at             timestamptz
  resolution              varchar(200)[note: "Explanation entered by Fleet Manager on review"]
  created_at              timestamptz [not null, default: `now()`]

  indexes {
    (asset_id, created_at desc)
    (reviewed_at)
  }
}

Table UtilizationLog {
  id                      uuid        [pk]
  asset_id                uuid        [not null, note: "FK to Asset"]
  driver_id               uuid        [not null, note: "FK to Driver"]
  project_id              uuid        [not null, ref: > Project.id]
  log_date                date        [not null]
  shift                   varchar(10) [not null, note: "AM / PM / Night / Full-Day"]
  available_hours         decimal(4,2)[not null, note: "Hours the asset was available in this shift"]
  productive_hours        decimal(4,2)[not null, note: "Hours the asset was actually working"]
  idle_hours              decimal(4,2)[not null, note: "Available but not working"]
  downtime_hours          decimal(4,2)[not null, default: 0, note: "Hours under breakdown or maintenance"]
  utilization_rate        decimal(5,2)[not null, note: "productive_hours / available_hours * 100. Auto-calculated."]
  opening_hour_meter      decimal(10,2)
  closing_hour_meter      decimal(10,2)
  operator_remarks        text
  entered_by              uuid        [not null, note: "FK to Employee"]
  created_at              timestamptz [not null, default: `now()`]

  indexes {
    (asset_id, log_date desc, shift) [unique]
    (project_id, log_date desc)
    (driver_id, log_date desc)
  }
}

Table SparePart {
  id                  uuid        [pk]
  part_number         varchar(100)[unique, not null]
  part_description    varchar(300)[not null]
  part_category       varchar(100)[note: "Engine / Hydraulics / Electrical / Filters / Tyres / Body / Undercarriage"]
  compatible_sub_types text       [note: "Comma-separated sub_type_codes. Application-layer enforced."]
  unit_of_measure     varchar(20) [not null, note: "Each / Set / Liter / Meter / Kg"]
  oem_part_number     varchar(100)
  reorder_level       decimal(8,2)
  current_stock       decimal(8,2)[default: 0]
  unit_cost_estimate  decimal(10,2)
  is_active           boolean     [not null, default: true]
  created_at          timestamptz [not null, default: `now()`]
  updated_at          timestamptz [not null, default: `now()`]
}