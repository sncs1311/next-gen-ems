# Database (SRS 4.4)
DATABASE_URL="postgresql://ems_user:changeme@localhost:5432/ems_db?schema=public"

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"

# Auth (SRS NFR-SEC-001, NFR-SEC-002) — generate with `openssl rand -base64 48`
JWT_ACCESS_SECRET="replace-with-a-long-random-secret"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-secret"
JWT_ACCESS_EXPIRY="8h"
JWT_REFRESH_EXPIRY="7d"

# Seed script — only used by `npm run seed`; leave unset to skip creating an admin account
SEED_ADMIN_PASSWORD=""

# ML service (SRS 4.5) — not yet built (Phase 4)
ML_SERVICE_BASE_URL="http://localhost:8000"
