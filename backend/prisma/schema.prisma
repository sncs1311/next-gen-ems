generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ADDED — not present in the Phase 1 data dictionary / ERD. The SRS (§4.7, §4.9)
// specifies AuthService.logout() and JWTService.invalidateRefreshToken(jti), but
// no table exists to persist which refresh tokens are valid/revoked — without one,
// "logout" can't actually revoke a still-unexpired refresh token. Flagging for the
// Data Dictionary / ERD to be updated to match.
model RefreshToken {
  id          String    @id @default(uuid())
  jti         String    @unique
  employeeId  String    @map("employee_id")
  employee    Employee  @relation(name: "RefreshToken_employee_id", fields: [employeeId], references: [id])
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([employeeId])
}

model IncidentReport {
  id                           String  @id @default(uuid())
  incidentNumber               String  @unique @db.VarChar(30) @map("incident_number")
  assetId                      String  @map("asset_id")
  asset                        Asset  @relation(name: "IncidentReport_asset_id", fields: [assetId], references: [id])
  driverId                     String  @map("driver_id")
  driver                       Driver  @relation(name: "IncidentReport_driver_id", fields: [driverId], references: [id])
  projectId                    String?  @map("project_id")
  project                      Project?  @relation(name: "IncidentReport_project_id", fields: [projectId], references: [id])
  yardLocationId               String?  @map("yard_location_id")
  yardLocation                 WarehouseYardLocation?  @relation(name: "IncidentReport_yard_location_id", fields: [yardLocationId], references: [id])
  transferRequestId            String?  @map("transfer_request_id")
  incidentType                 String  @db.VarChar(50) @map("incident_type")
  occurredAt                   DateTime  @map("occurred_at")
  reportedAt                   DateTime  @default(now()) @map("reported_at")
  reportedBy                   String  @map("reported_by")
  reportedByEmployee           Employee  @relation(name: "IncidentReport_reported_by", fields: [reportedBy], references: [id])
  thirdPartyInvolved           Boolean  @default(false) @map("third_party_involved")
  thirdPartyVehiclePlate       String?  @db.VarChar(30) @map("third_party_vehicle_plate")
  thirdPartyCompany            String?  @db.VarChar(200) @map("third_party_company")
  thirdPartyDriverName         String?  @db.VarChar(200) @map("third_party_driver_name")
  thirdPartyInsuranceDetails   String?  @map("third_party_insurance_details")
  personalInjuryOccurred       Boolean  @default(false) @map("personal_injury_occurred")
  injuredPersonsDetails        String?  @map("injured_persons_details")
  medicalAttentionRequired     Boolean  @default(false) @map("medical_attention_required")
  hospitalizationOccurred      Boolean  @default(false) @map("hospitalization_occurred")
  medicalFacility              String?  @db.VarChar(300) @map("medical_facility")
  policeReportNumber           String?  @db.VarChar(100) @map("police_report_number")
  insuranceClaimNumber         String?  @db.VarChar(100) @map("insurance_claim_number")
  estimatedDamageCost          Decimal?  @db.Decimal(12,2) @map("estimated_damage_cost")
  estimatedThirdPartyClaim     Decimal?  @db.Decimal(12,2) @map("estimated_third_party_claim")
  rootCauseCategory            String?  @db.VarChar(50) @map("root_cause_category")
  rootCauseDescription         String?  @map("root_cause_description")
  correctiveAction             String?  @map("corrective_action")
  investigatedBy               String?  @map("investigated_by")
  investigatedByEmployee       Employee?  @relation(name: "IncidentReport_investigated_by", fields: [investigatedBy], references: [id])
  investigationStartDate       DateTime?  @db.Date @map("investigation_start_date")
  closureDate                  DateTime?  @db.Date @map("closure_date")
  incidentStatus               String  @default("Open") @db.VarChar(20) @map("incident_status")
  isArchived                   Boolean  @default(false) @map("is_archived")
  createdAt                    DateTime  @default(now()) @map("created_at")
  updatedAt                    DateTime  @map("updated_at") @updatedAt
  incidentMediaIncidentIdList  IncidentMedia[]  @relation(name: "IncidentMedia_incident_id")
}

model IncidentMedia {
  id                           String  @id @default(uuid())
  incidentId                   String  @map("incident_id")
  incident                     IncidentReport  @relation(name: "IncidentMedia_incident_id", fields: [incidentId], references: [id])
  mediaType                    String  @db.VarChar(20) @map("media_type")
  fileName                     String  @db.VarChar(255) @map("file_name")
  filePathUrl                  String  @map("file_path_url")
  fileSizeBytes                Int?  @map("file_size_bytes")
  mimeType                     String?  @db.VarChar(100) @map("mime_type")
  caption                      String?  @db.VarChar(300)
  uploadedBy                   String  @map("uploaded_by")
  uploadedByEmployee           Employee  @relation(name: "IncidentMedia_uploaded_by", fields: [uploadedBy], references: [id])
  uploadedAt                   DateTime  @default(now()) @map("uploaded_at")
}

